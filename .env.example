# Server
PORT=3000
HOST=127.0.0.1
MAX_JSON_BODY_BYTES=1048576

# LLM and extraction
# Default hosted mode uses OpenRouter's OpenAI-compatible Responses API.
# Fill OPENAI_API_KEY later with your OpenRouter key.
# If you want direct OpenAI instead, switch OPENAI_BASE_URL back to
# https://api.openai.com/v1 and update the model ids.
# To run the bundled local adapter instead:
# - set LLM_PROVIDER=local_openai_compatible
# - keep OPENAI_API_KEY empty
# - point LOCAL_LLM_BASE_URL at the adapter
# - set OPENAI_MODEL and FINANCIAL_ADVISOR_MODEL to the local model id
# See docs/local-qwen-macmini.md for the full local setup notes.
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-5-mini
LINKEDIN_COMPOSER_MODEL=openai/gpt-5-mini
CLAIM_EXTRACTION_MODE=auto
CLAIM_EXTRACTION_PROMPT_VERSION=claim-extractor-v2
OPENAI_BASE_URL=https://openrouter.ai/api/v1
# Supported: openai, local_openai_compatible
LLM_PROVIDER=openai
# Used when LLM_PROVIDER=local_openai_compatible
LOCAL_LLM_BASE_URL=http://127.0.0.1:8001/v1
LOCAL_LLM_API_KEY=local-dev-token
LOCAL_LLM_MODEL=qwen3-4b-local
FINANCIAL_ADVISOR_MODEL=openai/gpt-5-mini
IMPACT_MAPPER_MODE=auto
IMPACT_MAPPER_MODEL=openai/gpt-5-mini
IMPACT_MAPPER_MAX_RETRIES=2
IMPACT_MAPPER_RETRY_BASE_MS=800

# Background pipeline
# If PIPELINE_SCHEDULE_TIMES is set, the scheduler runs at those exact local times.
# Times are HH:MM in the configured timezone.
PIPELINE_SCHEDULE_TIMES=
PIPELINE_SCHEDULE_TIMEZONE=Europe/Berlin
# Fallback interval mode when PIPELINE_SCHEDULE_TIMES is empty.
# Set to 0 to disable the scheduler locally.
PIPELINE_INTERVAL_MINUTES=15
# Manual-feed backlog sweep. Only matters when the saved feed is manual.
MANUAL_FEED_CRON_INTERVAL_HOURS=6
MANUAL_FEED_CRON_MAX_POST_AGE_HOURS=24

# Notifications
NOTIFICATION_PROVIDER=disabled
NOTIFICATIONS_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE_URL=https://api.telegram.org
# Enable Telegram long-polling commands like /help, /status, /digest, /polymarket, /ingest, and /linkedin.
TELEGRAM_COMMANDS_ENABLED=0
# Optional. Restrict bot commands to a single chat id.
# Defaults to TELEGRAM_CHAT_ID when empty.
TELEGRAM_ALLOWED_CHAT_ID=
# Long-poll timeout for Telegram getUpdates requests.
TELEGRAM_POLLING_TIMEOUT_SECONDS=30

# Polymarket
# Public market data works without auth. Live order placement additionally needs:
# - a Polymarket private key
# - the right signature type / funder setup
# - a non-blocked egress IP according to Polymarket geoblocking
POLYMARKET_GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_BASE_URL=https://clob.polymarket.com
POLYMARKET_SITE_BASE_URL=https://polymarket.com
POLYMARKET_API_TIMEOUT_MS=8000
POLYMARKET_DEFAULT_MARKETS_LIMIT=24
POLYMARKET_DEFAULT_ACTIVE_ONLY=1
POLYMARKET_CHAIN_ID=137
POLYMARKET_AGENT_MODEL=openai/gpt-5-mini
# 0 = EOA, 1 = proxy, 2 = gnosis safe
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_PRIVATE_KEY=
# Optional: persist existing L2 API credentials instead of deriving them on demand.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Macro and filing intel
# FRED is free and only needed if you want the macro overlay active.
FRED_API_KEY=
# SEC EDGAR does not require an API key, but a descriptive user agent is recommended.
SEC_API_USER_AGENT=
SEC_API_TIMEOUT_MS=8000

# Market data
# Supported: auto, stooq, mock
MARKET_DATA_PROVIDER=auto
MARKET_DATA_TIMEOUT_MS=8000

# Paper trading quotes
# Supported: auto, twelve-data, none
PAPER_TRADE_PRICE_PROVIDER=auto
PAPER_TRADE_PRICE_CACHE_TTL_MS=20000
PAPER_TRADE_PRICE_TIMEOUT_MS=6000
TWELVE_DATA_API_KEY=

# Trade readiness
# Supported: fail-closed, advisory
TRADE_READY_MODE=fail-closed
TRADE_READY_MAX_SNAPSHOT_AGE_HOURS=24

# Feed provider
# Supported: fake, manual, x-api
# Use manual when you want to feed posts through the Signals form or Telegram /ingest
# instead of relying on the X API.
FEED_PROVIDER=fake
X_API_BEARER_TOKEN=
X_API_KEY=
X_API_BASE_URL=https://api.x.com/2
X_API_MAX_RESULTS_PER_SOURCE=8
