# Server
PORT=3000
HOST=127.0.0.1

# Claim extraction
# Leave OPENAI_API_KEY empty until you're ready to validate live extraction.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CLAIM_EXTRACTION_MODE=auto
CLAIM_EXTRACTION_PROMPT_VERSION=claim-extractor-v2
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=openai
LOCAL_LLM_BASE_URL=http://127.0.0.1:8001/v1
LOCAL_LLM_API_KEY=local-dev-token
LOCAL_LLM_MODEL=qwen3-4b-local
FINANCIAL_ADVISOR_MODEL=gpt-4.1-mini

# Background pipeline
# Set to 0 to disable the scheduler locally.
PIPELINE_INTERVAL_MINUTES=15

# Notifications
NOTIFICATION_PROVIDER=disabled
NOTIFICATIONS_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_API_BASE_URL=https://api.telegram.org

# Market data
# Supported: auto, stooq, mock
MARKET_DATA_PROVIDER=auto
MARKET_DATA_TIMEOUT_MS=8000

# Feed provider
# Supported: fake, manual, x-api
FEED_PROVIDER=fake
X_API_BEARER_TOKEN=
X_API_KEY=
X_API_BASE_URL=https://api.x.com/2
X_API_MAX_RESULTS_PER_SOURCE=8
